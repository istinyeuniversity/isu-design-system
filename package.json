{
  "name": "isu-design-system",
  "version": "2.4.0",
  "type": "module",
  "description": "Official design system for Istinye University - Tailwind CSS based components and styles",
  "main": "dist/isu.js",
  "style": "dist/isu.css",
  "tailwind": "./tailwind-preset.js",
  "exports": {
    ".": {
      "import": "./dist/isu.esm.js",
      "require": "./dist/isu.js",
      "default": "./dist/isu.js"
    },
    "./dist/isu.js": "./dist/isu.js",
    "./dist/isu.esm.js": "./dist/isu.esm.js",
    "./dist/isu.css": "./dist/isu.css",
    "./tailwind-preset.js": "./tailwind-preset.js",
    "./src/css/isu.css": "./src/css/isu.css",
    "./src/components/*": "./src/components/*"
  },
  "files": [
    "dist/",
    "src/",
    "tailwind-preset.js"
  ],
  "scripts": {
    "tokens": "node build-tokens.js",
    "build:css": "npx tailwindcss -i ./src/css/isu.css -o ./dist/isu.css --minify",
    "build:js": "esbuild src/js/index.js --bundle --format=iife --global-name=ISU --minify --outfile=dist/isu.js --banner:js=\"/*! isu-design-system v2.4.0 | MIT */\"",
    "build:esm": "esbuild src/js/index.js --bundle --format=esm --minify --outfile=dist/isu.esm.js --banner:js=\"/*! isu-design-system v2.4.0 | MIT */\"",
    "build": "npm run tokens && npm run build:css && npm run build:js && npm run build:esm",
    "dev": "npm run tokens && npx tailwindcss -i ./src/css/isu.css -o ./dist/isu.css --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "standard-version",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "design-system",
    "istinye-university",
    "tailwindcss",
    "university",
    "turkey"
  ],
  "author": "Istinye University",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/istinyeuniversity/isu-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/istinyeuniversity/isu-design-system/issues"
  },
  "homepage": "https://github.com/istinyeuniversity/isu-design-system#readme",
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/html": "^10.3.6",
    "@storybook/html-vite": "^10.3.6",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.6",
    "standard-version": "^9.5.0",
    "storybook": "^10.3.6",
    "style-dictionary": "^5.1.1",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "standard-version": {
      "dotgitignore": {
        "minimatch": {
          "brace-expansion": "1.1.13"
        }
      }
    }
  }
}
